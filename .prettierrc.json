{
  "singleQuote": true,
  "semi": true,
  "trailingComma": "all",
  "printWidth": 100,
  "plugins": ["prettier-plugin-astro", "prettier-plugin-tailwindcss"],
  "overrides": [
    { "files": "*.astro", "options": { "parser": "astro" } },
    {
      "comment": "Blog posts embed code samples (some are intentional fragments). Format the prose, never rewrite the code blocks.",
      "files": "*.md",
      "options": { "embeddedLanguageFormatting": "off" }
    }
  ]
}
