---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import ZoneCard from '../components/home/ZoneCard.astro';
import ChangelogFeed from '../components/home/ChangelogFeed.astro';
import SectionLabel from '../components/content/SectionLabel.astro';
import { getChangelog } from '../lib/collections.ts';
import { SITE } from '../config/site.ts';

const blurbs = {
  blog: 'building, debugging, and career detours',
  podcast: '[WIP] · real talk with builders',
  speaking: 'workshops, talks, panels',
  projects: 'side projects, tools, experiments',
};
const changelog = await getChangelog(6);
---

<BaseLayout title={SITE.name}>
  <Hero />
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.6rem;margin-top:1.4rem">
    <ZoneCard zone="blog" blurb={blurbs.blog} />
    <ZoneCard zone="podcast" blurb={blurbs.podcast} />
    <ZoneCard zone="speaking" blurb={blurbs.speaking} />
    <ZoneCard zone="projects" blurb={blurbs.projects} />
  </div>
  <SectionLabel label="// changelog" />
  <ChangelogFeed entries={changelog} />
  <a
    href="/changelog"
    class="hov-link"
    style="display:inline-block;margin-top:1rem;font-family:var(--font-mono);font-size:0.7rem;color:var(--text-muted)"
    >→ full changelog</a
  >
</BaseLayout>
