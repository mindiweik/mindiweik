---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { readingTime } from '../../lib/reading-time.ts';
import { isVisible, publishState } from '../../lib/publish.ts';

export async function getStaticPaths() {
  const posts = await getCollection('blog', isVisible);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
const mins = post.data.readingTime ?? readingTime(post.body ?? '');
---

<ArticleLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.ogImage}
  slug={post.id}
  date={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  readingMins={mins}
  youtubeUrl={post.data.youtubeUrl}
  state={publishState(post.data, new Date())}
>
  <Content />
</ArticleLayout>
