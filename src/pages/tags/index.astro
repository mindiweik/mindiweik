---
import ZoneIndexLayout from '../../layouts/ZoneIndexLayout.astro';
import EntryCard from '../../components/content/EntryCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', (e) => !e.data.draft);
const counts = new Map<string, number>();
for (const p of posts) for (const t of p.data.tags ?? []) counts.set(t, (counts.get(t) ?? 0) + 1);
const tags = [...counts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---
<ZoneIndexLayout zone="blog" heading="tags" sub="browse posts by topic.">
  {tags.map(([tag, count]) => (
    <EntryCard
      href={`/tags/${tag}`}
      title={`#${tag}`}
      meta={`${count} post${count === 1 ? '' : 's'}`}
      zone="blog"
    />
  ))}
</ZoneIndexLayout>
