---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/content/SectionLabel.astro';
import VersionChip from '../components/content/VersionChip.astro';
import KofiCard from '../components/support/KofiCard.astro';

const now = [
  { dot: '--accent-blog', k: 'onboarding', v: 'new providers @ OpenRouter' },
  { dot: '--accent-projects', k: 'shipping', v: 'Audition Cat (alpha), Drip Dash, MARVIN' },
  { dot: '--accent-podcast', k: 'hosting', v: '[WIP] podcast, season 1' },
  { dot: '--accent-speaking', k: 'training', v: 'Denver Colfax marathon' },
];
---
<BaseLayout title="about" active="/about">
  <div style="font-family:var(--font-mono);font-size:0.65rem;color:var(--text-muted);padding-top:1.6rem">~/about.md</div>
  <div style="margin-top:0.7rem"><VersionChip label="v2.0.0 · current release" zone="blog" /></div>
  <h1 style="font-family:var(--font-display);font-weight:700;font-size:1.9rem;line-height:1.5;letter-spacing:-0.02em;margin:0.8rem 0 0"><span style="background:var(--accent-blog);color:var(--ink);padding:0.08em 0.34em;border-radius:7px;box-decoration-break:clone;-webkit-box-decoration-break:clone">I build things, then write about figuring them out.</span></h1>
  <div style="font-family:var(--font-body);font-size:0.95rem;line-height:1.65;color:var(--text);opacity:0.9;margin-top:1rem">
    <p>I'm a software engineer who likes the seams: the places where systems, people, and process all have to agree. I got here the long way, with a communication degree and a studio art minor, five-plus years leading teams and untangling client relationships in real estate and marketing, then a bootcamp and a hard pivot into code. That detour isn't a footnote. It's why I build thinking about the user, the stakeholder, and the system all at once.</p>
    <p>These days I'm at OpenRouter, onboarding new providers and pulling more of the AI ecosystem into one place developers can actually reach. On the side, I'm a founding engineer on Audition Cat, a CRM for performing artists that's three years in the making and finally in alpha. And when I'm off the clock, I help organize Colorado Women&amp;TECH and show up for the community through speaking and writing.</p>
    <p>This site is where the build log lives: essays, the [WIP] podcast, talks, and whatever I'm shipping. Life doesn't have release notes, so I write my own.</p>
  </div>

  <SectionLabel label="// status" />
  <div style="font-family:var(--font-mono);font-size:0.8rem">
    {now.map((r) => (
      <div style="display:flex;gap:0.6rem;align-items:baseline;padding:0.5rem 0;border-top:1px solid var(--border)">
        <span style={`width:0.5rem;height:0.5rem;border-radius:50%;flex:none;background:var(${r.dot})`}></span>
        <span style="flex:none;width:4.5rem;color:var(--text-muted)">{r.k}</span>
        <span>{r.v}</span>
      </div>
    ))}
  </div>

  <KofiCard />
</BaseLayout>
