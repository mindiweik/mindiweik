---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/content/SectionLabel.astro';
import VersionChip from '../components/content/VersionChip.astro';
import KofiCard from '../components/support/KofiCard.astro';

const now = [
  { dot: '--accent-blog', k: 'building', v: 'infra & model onboarding @ OpenRouter' },
  { dot: '--accent-projects', k: 'shipping', v: 'Audition Cat (alpha), Drip Dash, MARVIN' },
  { dot: '--accent-podcast', k: 'hosting', v: '[WIP] podcast, season 1' },
  { dot: '--accent-speaking', k: 'training', v: 'Denver Colfax marathon' },
];
const crew = ['Rigby · mini aussie', 'Rayla · cattle dog / husky', 'Robin · breed TBD', 'Buzz · gray cat'];
---
<BaseLayout title="about" active="/about">
  <div style="font-family:var(--font-mono);font-size:0.65rem;color:var(--text-muted);padding-top:1.6rem">~/about.md</div>
  <div style="margin-top:0.7rem"><VersionChip label="v2.0.0 · current release" zone="blog" /></div>
  <h1 style="font-family:var(--font-display);font-weight:700;font-size:1.9rem;line-height:1.1;letter-spacing:-0.02em;margin:0.8rem 0 0">I build things, then write about figuring them out.</h1>
  <div style="font-family:var(--font-body);font-size:0.95rem;line-height:1.65;color:var(--text);opacity:0.9;margin-top:1rem">
    <p>Placeholder bio. (Copy revisited later.) Software engineer at OpenRouter, founding engineer on Audition Cat, career changer from real estate and marketing by way of a Studio Art degree and a bootcamp.</p>
    <p>This site is where the build log lives: essays, the [WIP] podcast, talks, and the things I'm shipping. Life doesn't have release notes, so I write my own.</p>
  </div>

  <SectionLabel label="// currently" />
  <div style="font-family:var(--font-mono);font-size:0.8rem">
    {now.map((r) => (
      <div style="display:flex;gap:0.6rem;align-items:baseline;padding:0.5rem 0;border-top:1px solid var(--border)">
        <span style={`width:0.5rem;height:0.5rem;border-radius:50%;flex:none;background:var(${r.dot})`}></span>
        <span style="flex:none;width:4.5rem;color:var(--text-muted)">{r.k}</span>
        <span>{r.v}</span>
      </div>
    ))}
  </div>

  <SectionLabel label="// the crew 🐾" />
  <div style="display:flex;flex-wrap:wrap;gap:0.5rem">
    {crew.map((c) => (
      <span style="font-family:var(--font-mono);font-size:0.7rem;padding:0.4rem 0.7rem;border-radius:8px;border:1px solid var(--border)">{c}</span>
    ))}
  </div>

  <KofiCard />
</BaseLayout>
