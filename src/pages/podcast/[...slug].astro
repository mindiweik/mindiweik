---
import { getCollection, render } from 'astro:content';
import EpisodeLayout from '../../layouts/EpisodeLayout.astro';
import { isVisible, publishState } from '../../lib/publish.ts';

export async function getStaticPaths() {
  const eps = await getCollection('podcast', isVisible);
  return eps.map((ep) => ({ params: { slug: ep.id }, props: { ep } }));
}
const { ep } = Astro.props;
const { Content } = await render(ep);
const d = ep.data;
---

<EpisodeLayout
  id={ep.id}
  title={d.title}
  version={d.version}
  season={d.season}
  pubDate={d.pubDate}
  duration={d.duration}
  descriptor={d.descriptor}
  youtubeUrl={d.youtubeUrl}
  chapters={d.chapters}
  links={d.links}
  state={publishState(d, new Date())}
>
  <Content />
</EpisodeLayout>
