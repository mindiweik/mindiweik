---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import VersionChip from '../components/content/VersionChip.astro';
import { isVisible } from '../lib/publish.ts';

// Every visible route on the site, inlined at build time so the 404 page can
// fuzzy-match the requested path client-side and suggest close matches.
const blogEntries = (await getCollection('blog')).filter(isVisible);
const blog = blogEntries.map((e) => `/blog/${e.id}`);
const podcast = (await getCollection('podcast')).filter(isVisible).map((e) => `/podcast/${e.id}`);
const speaking = (await getCollection('speaking')).filter(isVisible).map((e) => `/speaking/${e.id}`);
const tags = [...new Set(blogEntries.flatMap((e) => e.data.tags))].map((t) => `/tags/${t}`);
const routes = ['/', '/blog', '/podcast', '/speaking', '/projects', '/about', '/changelog', '/tags', ...blog, ...podcast, ...speaking, ...tags];
---
<BaseLayout title="404">
  <div style="padding:4rem 0;text-align:center">
    <VersionChip label="404" zone="podcast" />
    <h1 style="font-family:var(--font-display);font-weight:700;font-size:1.9rem;letter-spacing:-0.02em;margin:1.2rem 0 0">this version doesn't exist (yet)</h1>
    <p style="font-family:var(--font-body);color:var(--text-muted);margin-top:0.8rem">the page you're looking for moved, shipped, or never made it past the cutting room floor.</p>
    <div id="suggestions" style="display:none;margin-top:1.8rem">
      <div style="font-family:var(--font-mono);font-size:0.65rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-muted)">// did you mean</div>
      <ul id="suggestion-list" style="list-style:none;padding:0;margin:0.9rem 0 0;display:flex;flex-direction:column;gap:0.6rem;align-items:center"></ul>
    </div>
    <a href="/" style="display:inline-block;margin-top:1.6rem;font-family:var(--font-mono);font-weight:700;font-size:0.8rem;padding:0.6rem 1rem;border-radius:8px;background:var(--accent-blog);color:var(--ink)">&larr; back home</a>
  </div>
</BaseLayout>

<script define:vars={{ routes }}>
  // section names carry no signal for overlap ("/blog/garbage" shouldn't match every blog post)
  const SECTIONS = new Set(['blog', 'podcast', 'speaking', 'tags', 'projects', 'about', 'changelog']);
  const tokenize = (p) => p.toLowerCase().split(/[^a-z0-9]+/).filter((t) => t.length > 2 && !SECTIONS.has(t));

  function levenshtein(a, b) {
    const m = a.length, n = b.length;
    if (!m) return n;
    if (!n) return m;
    let prev = Array.from({ length: n + 1 }, (_, i) => i);
    for (let i = 1; i <= m; i++) {
      const cur = [i];
      for (let j = 1; j <= n; j++) {
        cur[j] = Math.min(prev[j] + 1, cur[j - 1] + 1, prev[j - 1] + (a[i - 1] === b[j - 1] ? 0 : 1));
      }
      prev = cur;
    }
    return prev[n];
  }

  const wanted = decodeURIComponent(location.pathname).replace(/\/+$/, '') || '/';
  const wantedTokens = tokenize(wanted);
  const wantedLast = wanted.split('/').pop() || '';

  const scored = routes
    .map((route) => {
      const overlap = tokenize(route).filter((t) => wantedTokens.includes(t)).length;
      const last = route.split('/').pop() || route;
      const lev = levenshtein(wantedLast, last) / Math.max(wantedLast.length, last.length, 1);
      return { route, overlap, lev, score: overlap * 2 + (1 - lev) };
    })
    .filter((s) => s.overlap >= 1 || s.lev <= 0.4)
    .sort((a, b) => b.score - a.score)
    .slice(0, 5);

  if (scored.length) {
    const list = document.getElementById('suggestion-list');
    for (const { route } of scored) {
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = route;
      a.textContent = route;
      a.style.cssText = 'display:inline-block;font-family:var(--font-mono);font-weight:700;font-size:0.8rem;padding:0.55rem 1rem;border-radius:8px;background:var(--surface);border:1px solid var(--border);color:var(--text);text-decoration:none';
      li.appendChild(a);
      list.appendChild(li);
    }
    document.getElementById('suggestions').style.display = 'block';
  }
</script>
