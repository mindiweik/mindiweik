---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/content/Breadcrumb.astro';
import VersionChip from '../components/content/VersionChip.astro';
import PublishStateChip from '../components/content/PublishStateChip.astro';
import type { PublishState } from '../lib/publish.ts';
import RelatedPosts from '../components/content/RelatedPosts.astro';
import Comments from '../components/content/Comments.astro';
import SubscribeForm from '../components/content/SubscribeForm.astro';
import KofiCard from '../components/support/KofiCard.astro';
import JsonLd from '../components/layout/JsonLd.astro';
import { blogPostingSchema } from '../lib/schema.ts';
import { canonicalUrl } from '../lib/urls.ts';
import { SITE } from '../config/site.ts';
import '../styles/prose.css';
interface Props {
  title: string;
  slug: string;
  date: Date;
  updatedDate?: Date;
  tags: string[];
  readingMins: number;
  youtubeUrl?: string;
  state?: PublishState;
  description?: string;
  image?: string;
}
const { title, slug, date, updatedDate, tags, readingMins, youtubeUrl, state, description, image } =
  Astro.props;
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const ytId = youtubeUrl
  ? (youtubeUrl.match(/(?:v=|youtu\.be\/|embed\/)([\w-]{11})/)?.[1] ?? null)
  : null;
const pageUrl = canonicalUrl(Astro.url.pathname, Astro.site ?? new URL(SITE.url));
const schemaImage = new URL(image ?? '/og/blog.png', SITE.url).href;
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  zone="blog"
  active="/blog"
  type="article"
  pubDate={date}
>
  <JsonLd
    schema={blogPostingSchema({
      title,
      description,
      url: pageUrl,
      datePublished: date,
      dateModified: updatedDate,
      image: schemaImage,
      tags,
    })}
  />
  <Breadcrumb path={`~/blog/${slug}.mdx`} />
  <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;margin-top:0.7rem">
    <VersionChip label="blog" zone="blog" />
    <PublishStateChip state={state} zone="blog" />
    <span style="font-family:var(--font-mono);font-size:0.62rem;color:var(--text-muted)"
      >{readingMins} min</span
    >
    {
      tags.map((t) => (
        <a
          href={`/tags/${t}`}
          class="hov-link"
          style="font-family:var(--font-mono);font-size:0.62rem;color:var(--text-muted);text-decoration:underline;text-underline-offset:2px"
        >
          #{t}
        </a>
      ))
    }
  </div>
  <h1
    style="font-family:var(--font-display);font-weight:700;font-size:1.8rem;line-height:1.1;letter-spacing:-0.02em;margin:0.8rem 0 0"
  >
    {title}
  </h1>
  <div
    style="font-family:var(--font-mono);font-size:0.62rem;color:var(--text-muted);margin-top:0.6rem"
  >
    {fmt(date)}
  </div>
  {
    ytId && (
      <div style="margin-top:1.2rem;position:relative;width:100%;aspect-ratio:16/9;border-radius:10px;overflow:hidden;border:1px solid var(--border)">
        <iframe
          src={`https://www.youtube-nocookie.com/embed/${ytId}`}
          title={title}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          style="position:absolute;inset:0;width:100%;height:100%;border:0"
        />
      </div>
    )
  }
  <article class="prose" style="margin-top:1.2rem"><slot /></article>
  <div
    style="margin-top:2.4rem;padding-top:1.2rem;border-top:1px solid var(--border);font-family:var(--font-display);font-size:1rem;color:var(--text-muted)"
  >
    thanks so much for reading! ✨
  </div>
  <KofiCard />
  <RelatedPosts currentId={slug} />
  <Comments pageKey={`blog/${slug}`} zone="blog" />
  <SubscribeForm variant="inline" zone="blog" />
</BaseLayout>
