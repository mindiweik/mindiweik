---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/content/Breadcrumb.astro';
import VersionChip from '../components/content/VersionChip.astro';
import '../styles/prose.css';
interface Props {
  id: string; title: string; version: string; season: number; pubDate: Date;
  duration?: string; descriptor?: string;
  chapters: { timestamp: string; title: string }[];
  links: { label: string; url: string }[];
}
const { id, title, version, season, pubDate, duration, descriptor, chapters, links } = Astro.props;
const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<BaseLayout title={title} active="/podcast">
  <Breadcrumb path={`~/podcast/${id}`} />
  <div style="display:flex;gap:0.5rem;align-items:center;margin-top:0.7rem">
    <VersionChip label={version} zone="podcast" />
    <span style="font-family:var(--font-mono);font-size:0.62rem;color:var(--text-muted)">{duration ? duration + ' · ' : ''}season {season}</span>
  </div>
  <h1 style="font-family:var(--font-display);font-weight:700;font-size:1.7rem;line-height:1.1;letter-spacing:-0.02em;margin:0.8rem 0 0">{title}</h1>
  {descriptor && <p style="font-family:var(--font-body);color:var(--text-muted);font-size:0.85rem;margin-top:0.4rem">{descriptor}</p>}
  <div style="font-family:var(--font-mono);font-size:0.62rem;color:var(--text-muted);margin-top:0.6rem">[WIP] podcast · {fmt(pubDate)}</div>

  <!-- audio player placeholder (real island deferred to content-migration task) -->
  <div style="display:flex;gap:0.7rem;align-items:center;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:0.8rem;margin-top:1.1rem">
    <span style="width:2rem;height:2rem;border-radius:50%;background:var(--accent-podcast);color:var(--ink);display:flex;align-items:center;justify-content:center;flex:none">▶</span>
    <span style="flex:1;height:4px;border-radius:2px;background:var(--border)"></span>
    <span style="font-family:var(--font-mono);font-size:0.6rem;color:var(--text-muted)">{duration ?? '--:--'}</span>
  </div>

  {chapters.length > 0 && (
    <div style="margin-top:1.1rem">
      {chapters.map((c) => (
        <div style="display:flex;gap:0.7rem;font-family:var(--font-mono);font-size:0.7rem;padding:0.45rem 0;border-top:1px solid var(--border)">
          <span style="color:var(--accent-podcast);flex:none">{c.timestamp}</span>
          <span>{c.title}</span>
        </div>
      ))}
    </div>
  )}

  <article class="prose" style="margin-top:1.2rem"><slot /></article>

  {links.length > 0 && (
    <div style="margin-top:1.4rem">
      <span style="font-family:var(--font-mono);font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-muted)">// the good stuff</span>
      <div style="margin-top:0.5rem;display:flex;flex-wrap:wrap;gap:0.5rem">
        {links.map((l) => (
          <a href={l.url} target="_blank" rel="noopener noreferrer" style="font-family:var(--font-mono);font-size:0.7rem;padding:0.35rem 0.6rem;border:1px solid var(--border);border-radius:6px">{l.label} →</a>
        ))}
      </div>
    </div>
  )}
</BaseLayout>
