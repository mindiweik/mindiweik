---
import '../styles/global.css';
import BaseHead from '../components/layout/BaseHead.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
interface Props {
  title: string;
  description?: string;
  image?: string;
  zone?: string;
  active?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
}
const { title, description, image, zone, active, type, pubDate } = Astro.props;
// Page-wide hover accent: interactive elements light up in the active zone's
// color (see the .hov-* rules in global.css). Mixed-zone spots override inline.
// Use the -text accent tokens: --hover-accent tints TEXT/outlines, so it must
// stay AA-legible on the light canvas (the bright fills don't). See global.css.
const ZONE_HOVER: Record<string, string> = {
  '/blog': '--accent-blog-text',
  '/podcast': '--accent-podcast-text',
  '/speaking': '--accent-speaking-text',
  '/projects': '--accent-projects-text',
};
const hoverAccent = ZONE_HOVER[active ?? ''] ?? '--accent-primary-text';
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      zone={zone}
      type={type}
      pubDate={pubDate}
    />
    <script is:inline>
      (function () {
        try {
          const t = localStorage.getItem('theme');
          if (t === 'light' || t === 'dark') {
            document.documentElement.setAttribute('data-theme', t);
          }
        } catch {
          /* storage blocked: fall back to the default data-theme */
        }
      })();
    </script>
  </head>
  <body
    style={`min-height:100vh;display:flex;flex-direction:column;--hover-accent:var(${hoverAccent})`}
  >
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header active={active} />
    <main
      id="main-content"
      style="flex:1;max-width:680px;margin:0 auto;width:100%;padding:0 1.4rem 4rem;box-sizing:border-box"
    >
      <slot />
    </main>
    <Footer />
  </body>
</html>
