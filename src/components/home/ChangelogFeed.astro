---
import type { ChangelogEntry } from '../../lib/collections.ts';
import { ZONES, zoneVar } from '../../lib/zones.ts';
interface Props { entries: ChangelogEntry[]; }
const { entries } = Astro.props;
const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
---
<div>
  {entries.map((e) => (
    <a href={e.url} style="display:flex;gap:0.7rem;align-items:baseline;padding:0.65rem 0;border-top:1px solid var(--border);font-family:var(--font-mono);font-size:0.8rem">
      <span style={`flex:none;width:3.4rem;font-size:0.6rem;font-weight:700;color:${zoneVar(e.zone)}`}>{e.type}</span>
      <span style="flex:1">{e.title}</span>
      <span style="color:var(--text-muted);font-size:0.65rem">{fmt(e.date)}</span>
    </a>
  ))}
</div>
