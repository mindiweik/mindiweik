---
import { SITE } from '../../config/site.ts';
---
<section style="padding:2.5rem 0 0.5rem">
  <h1 style="font-family:var(--font-display);font-weight:700;font-size:clamp(2rem,7vw,2.6rem);line-height:1.08;letter-spacing:-0.02em;margin:0">
    software engineer.<br />
    <span style="color:var(--accent-podcast)">writer.</span>
    <span style="color:var(--accent-blog)">builder.</span>
  </h1>
  <p style="font-family:var(--font-body);color:var(--text-muted);margin-top:0.8rem">{SITE.description}</p>
</section>
