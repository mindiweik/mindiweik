---
import type { ZoneKey } from '../../lib/zones.ts';
import { ZONES, zoneVar } from '../../lib/zones.ts';
interface Props {
  zone: ZoneKey;
  blurb: string;
}
const { zone, blurb } = Astro.props;
const z = ZONES[zone];
---

<a
  href={z.route}
  class="hov-fill"
  style={`display:block;border-radius:10px;padding:1rem 1.05rem;font-family:var(--font-mono);background:${zoneVar(zone)};color:var(--ink)`}
>
  <span style="display:block;font-weight:700;font-size:0.9rem">{z.label} →</span>
  <span style="display:block;font-size:0.72rem;margin-top:0.45rem;line-height:1.4">{blurb}</span>
</a>
