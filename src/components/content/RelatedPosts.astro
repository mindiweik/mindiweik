---
import { getCollection } from 'astro:content';
import { getRelatedPosts } from '../../lib/related.ts';
import { isVisible } from '../../lib/publish.ts';

interface Props { currentId: string; }
const { currentId } = Astro.props;
const posts = await getCollection('blog', isVisible);
const related = getRelatedPosts(currentId, posts, 4);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
{related.length > 0 && (
  <div style="margin-top:2.4rem">
    <span style="font-family:var(--font-mono);font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-muted)">// related posts</span>
    <div style="margin-top:0.5rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(min(240px,100%),1fr));gap:0.5rem">
      {related.map((p) => (
        <a href={`/blog/${p.id}`} style="display:block;padding:0.75rem 0.85rem;border:1px solid var(--border);border-radius:10px">
          <span style="display:block;font-family:var(--font-mono);font-size:0.6rem;color:var(--text-muted)">{fmt(p.data.pubDate)}</span>
          <span style="display:block;font-family:var(--font-display);font-weight:500;font-size:0.85rem;line-height:1.3;margin-top:0.35rem">{p.data.title}</span>
        </a>
      ))}
    </div>
  </div>
)}
