---
import { SITE } from '../../config/site.ts';
import KofiLink from '../support/KofiLink.astro';
const year = new Date().getFullYear();
---
<footer style="display:flex;flex-wrap:wrap;gap:1rem;align-items:center;justify-content:space-between;padding:2rem 1.4rem;border-top:1px solid var(--border);font-family:var(--font-mono);font-size:0.75rem;color:var(--text-muted)">
  <span>© {year} {SITE.author} · v2.0.0</span>
  <KofiLink />
</footer>
