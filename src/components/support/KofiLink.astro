  target="_blank"
  rel="noopener noreferrer"
  class="hov-link"
  style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-muted);--hover-accent:var(--accent-projects-text)"
>
  🧡 like what I make? <span
    style="color:var(--accent-projects-text);text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:2px"
    >support on ko-fi →</span
  >
</a>
